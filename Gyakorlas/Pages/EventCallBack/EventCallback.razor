@page "/eventCallbackDemo"
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Event Callback Demo</PageTitle>
<!--stílus netről szedve-->
<div class="container mt-4" style="max-width: 600px;">
    <div class="card shadow-sm border-0 rounded-3 p-4 bg-light">
        <h3 class="mb-4 text-primary fw-bold">Event Callback Demo Playground</h3>

        <div class="d-flex flex-wrap gap-2 mb-4">
            <button class="btn btn-outline-primary" @onclick="@Clicked">1. Sync Click</button>
            <button class="btn btn-outline-success" @onclick="@ClickedAsync">2. Async Click</button>
            <button class="btn btn-outline-warning" @onclick="@(async () => { 
                        Clicked(); await ClickedAsync(); LogAction("Combined Method Lambda Executed!"); })">
                3. Combined Lambda
            </button>
            <button class="btn btn-outline-danger" @onclick="@ClickWithArgs">4. With Mouse Args</button>
        </div>

        <div class="card border-0 rounded-3 bg-dark text-success p-3">
            <div class="d-flex justify-content-between align-items-center mb-2 border-bottom border-secondary pb-1">
                <span class="fw-bold tracking-wider text-uppercase small text-white-50">Console Log Output</span>
                <button class="btn btn-sm btn-outline-secondary text-white-50 border-0 py-0" @onclick="ClearLogs">Clear</button>
            </div>

            <div style="height: 150px; overflow-y: auto; font-family: monospace; font-size: 0.9rem;">
                @if (!logs.Any())
                {
                    <span class="text-muted italic">Click any button above to trace execution...</span>
                }
                else
                {
                    @foreach (var log in logs)
                    {
                        <div>@log</div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<string> logs = new();

    private void LogAction(string message)
    {
        logs.Insert(0, $"[{DateTime.Now.ToString("HH:mm:ss")}] {message}");
    }

    private void ClearLogs() => logs.Clear();

    void Clicked()
    {
        LogAction("Sync Clicked() method finished running.");
    }

    async Task ClickedAsync()
    {
        LogAction("Async ClickedAsync() starting delay simulation...");
        await Task.Delay(500); //várjál kicsikét mééég...
        LogAction("Async ClickedAsync() task successfully completed.");
    }

    void ClickWithArgs(MouseEventArgs args)
    {
        LogAction($"MouseArgs caught! Cursor Screen Position -> X: {args.ScreenX}, Y: {args.ScreenY}");
        LogAction($"Modifier keys pressed? Ctrl: {args.CtrlKey}, Shift: {args.ShiftKey}");
    }
}